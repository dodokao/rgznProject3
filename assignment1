import seaborn as sns

plt.rcParams['font.sans-serif'] = ['SimHei']
plt.rcParams['axes.unicode_minus'] = False

#开始定义要求的函数
"""
 目的：计算各线路乘客的平均搭乘站点数及其标准差
 Parameters
 ----------
 df : pd.DataFrame  预处理后的数据集
 route_col : str    线路号列名
 stops_col : str    搭乘站点数列名
 Returns
 -------
 pd.DataFrame  包含列：线路号、mean_stops、std_stops，按 mean_stops 降序排列
 """
def analyze_route_stops(df, route_col='线路号', stops_col='ride_stops'):
    result = df.groupby(route_col)[stops_col].agg(['mean', 'std']).reset_index()  # 计算均值和标准差
    result.columns = ['线路号', 'mean_stops', 'std_stops']
    result = result.sort_values('mean_stops', ascending=False)# 按均值降序排序
    return result

if __name__ == "__main__":
    df = pd.read_excel("ICData_clean.xlsx")  # 读取数据
    route_stats = analyze_route_stops(df)   # 调用函数并打印前10行
    print("=" * 60)
    print("✅ 各线路平均搭乘站点数（前10行）")
    print("=" * 60)
    print(route_stats.head(10).to_string(index=False))
    top15 = route_stats.head(15)# 取均值最高的前15条线路
    plt.figure(figsize=(11, 7))
    # 用seaborn来实现 水平条形图可视化
    sns.barplot(
        data=top15,
        x='mean_stops',#按要求处理X轴Y轴颜色title
        y='线路号',
        orient='h',
        palette='Blues_d',
        errorbar='se',# 误差棒显示标准差
        capsize=0.3 # 误差棒端点大小
    )

    # 图表格式
    plt.title('TOP15线路平均搭乘站点数', fontsize=14)
    plt.xlabel('平均搭乘站点数', fontsize=12)
    plt.ylabel('线路号', fontsize=12)
    plt.xlim(left=0)  # X轴从0开始
    plt.grid(alpha=0.3, axis='x')

    # 保存图片
    plt.tight_layout()
    plt.savefig('route_stops.png', dpi=150)
    plt.close()

    print("\n" + "=" * 60)
    print("✅ 任务3 全部完成！")
    print("📷 图片已保存：route_stops.png")
    print("=" * 60)

    # ==============================
    # 任务4 高峰小时系数 PHF 精确计算（自动识别高峰）
    # ==============================
    df = pd.read_excel("ICData_clean.xlsx")

    df['交易时间'] = pd.to_datetime(df['交易时间'])
    df['hour'] = df['交易时间'].dt.hour
    df['minute'] = df['交易时间'].dt.minute


    hourly_count = df.groupby('hour').size()
    peak_hour = hourly_count.idxmax()
    peak_volume = hourly_count.max()


    peak_df = df[df['hour'] == peak_hour].copy()

    peak_df['5min_bin'] = peak_df['minute'] // 5
    max5 = peak_df.groupby('5min_bin').size().max()
    phf5 = peak_volume / (12 * max5)


    peak_df['15min_bin'] = peak_df['minute'] // 15
    max15 = peak_df.groupby('15min_bin').size().max()
    phf15 = peak_volume / (4 * max15)

    print(f"高峰小时：{peak_hour:02d}:00 ~ {peak_hour + 1:02d}:00，刷卡量：{peak_volume} 次")
    print(f"最大5分钟刷卡量：{max5} 次")
    print(f"PHF5  = {peak_volume} / (12 × {max5}) = {phf5:.4f}")
    print(f"最大15分钟刷卡量：{max15} 次")
    print(f"PHF15 = {peak_volume} / ( 4 × {max15}) = {phf15:.4f}")
