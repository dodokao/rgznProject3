import matplotlib.pyplot as plt# 解决中文显示

plt.rcParams['font.sans-serif'] = ['SimHei']
plt.rcParams['axes.unicode_minus'] = False

df = pd.read_excel("ICData_clean.xlsx")# 读取清洗后的数据
total_count = len(df)

print("="*60)
print("✅ 任务2 运行开始")
print(f"全天总刷卡量：{total_count}")
print("="*60)

hour_data = df['hour'].values
hourly_count = np.bincount(hour_data, minlength=24)
hours = np.arange(0, 24)#使用 numpy 完成24小时分时统计，每一个小时唯一条矩阵

morning_count = df[df['hour'] < 7].shape[0]#早峰前统计加占比
night_count = df[df['hour'] >= 22].shape[0]#深夜时统计加占比

morning_ratio = morning_count / total_count * 100
night_ratio = night_count / total_count * 100

print("\n===== 时段刷卡量及占比 =====")
print(f"早峰前时段（hour < 7）：{morning_count} 次 | 占比 {morning_ratio:.2f}%")
print(f"深夜时段（hour >= 22）：{night_count} 次 | 占比 {night_ratio:.2f}%")

# 二、设置颜色：普通/早峰前/深夜 三色区分
colors = []
for h in hours:
    if h < 7:
        colors.append('orange')    # 早峰前：橙色
    elif h >= 22:
        colors.append('purple')    # 深夜：紫色
    else:
        colors.append('skyblue')   # 普通时段：天蓝色

# 绘制24小时柱状图，用的是要求的matplotlib
plt.figure(figsize=(12, 6))
plt.bar(hours, hourly_count, color=colors, edgecolor='black', linewidth=0.6)

plt.title('公交刷卡24小时流量分布', fontsize=14)#加title
plt.xlabel('小时（0-23）', fontsize=12)#处理x轴
plt.ylabel('刷卡次数', fontsize=12)#处理Y轴
plt.xticks(np.arange(0, 24, 1))
plt.grid(True, axis='y', alpha=0.3, linestyle='--')#加要求的横网格

# 三、保存图片：文件名 + dpi=150
plt.tight_layout()
plt.savefig("hour_distribution.png", dpi=150)#按要求设名字，dpi
plt.close()

print("\n" + "="*60)
print("✅ 任务2 全部完成！")
print("📷 图片已保存：hour_distribution.png (dpi=150)")
print("="*60)

