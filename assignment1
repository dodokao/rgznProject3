night_count = df[df['hour'] >= 22].shape[0]#深夜时统计加占比

morning_ratio = morning_count / total_count * 100
night_ratio = night_count / total_count * 100

print("\n===== 时段刷卡量及占比 =====")
print(f"早峰前时段（hour < 7）：{morning_count} 次 | 占比 {morning_ratio:.2f}%")
print(f"深夜时段（hour >= 22）：{night_count} 次 | 占比 {night_ratio:.2f}%")

# 二、设置颜色：普通/早峰前/深夜 三色区分
